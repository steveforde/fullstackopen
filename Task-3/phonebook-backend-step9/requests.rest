### Update a person (Replace ID with Sandra's or Tommy's ID)
PUT http://localhost:3001/api/persons/69c28c0c94db4841fcee6fba
Content-Type: application/json

{
    "name": "Sandra Pretty",
    "number": "085-999-888"
}